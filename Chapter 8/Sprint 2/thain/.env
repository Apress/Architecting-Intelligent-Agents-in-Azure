# ──────────────────────────────────────────────
# Sprint 2 — Identity & Secrets: Managed Identity + Environment Separation
# Replace all placeholder values with your own Azure resource details.
# In cloud mode (THAIN_AUTH_MODE=managed_identity), key-based credentials
# are not used — leave COSMOS_KEY and AZURE_SEARCH_API_KEY blank.
# ──────────────────────────────────────────────

# Azure AI Foundry
AZURE_AI_PROJECT_ENDPOINT=https://<your-foundry-host>.services.ai.azure.com/api/projects/<your-project>
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4o

# Cosmos DB
COSMOS_ENDPOINT=https://<your-cosmos-account>.documents.azure.com:443/
COSMOS_KEY=<your-cosmos-key>
COSMOS_DATABASE=db-thain
COSMOS_CONTAINER=Complaints
COSMOS_TTL_DAYS=1

# Semantic recall (Azure AI Search)
AZURE_SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net
AZURE_SEARCH_INDEX_NAME=thain-complaints
AZURE_SEARCH_API_KEY=<your-search-api-key>
AZURE_SEARCH_MODE=semantic
AZURE_SEARCH_TOP_K=3

# Embeddings
AZURE_OPENAI_EMBEDDING_ENDPOINT=https://<your-openai-host>.cognitiveservices.azure.com
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_EMBEDDING_API_KEY=<your-embedding-api-key>
AZURE_OPENAI_EMBEDDING_API_VERSION=2024-02-15-preview

# Feature flags
ENABLE_TICKETS=true
ENABLE_NOTIFICATIONS=true
ENABLE_DOCS=false
ENABLE_WRITE_APPROVALS=false

# Multi-agent behaviour
TRIAGE_MODE=deterministic
ENABLE_RECALL=true
ENABLE_KNOWLEDGE=true

# Customer context
THAIN_CUSTOMER_ID=thain-demo-v2

# ── Sprint 2 additions ──────────────────────────────────────────────────────

# Authentication mode: "local" uses az login; "managed_identity" uses Entra ID
THAIN_AUTH_MODE=local

# Azure Key Vault (required when THAIN_AUTH_MODE=managed_identity)
KEY_VAULT_URI=https://<your-keyvault-name>.vault.azure.net/

# Key Vault secret name for the embedding API key (managed identity mode)
KV_EMBEDDING_API_KEY_NAME=thain-embedding-api-key
