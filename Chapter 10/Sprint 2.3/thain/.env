# Azure OpenAI / Agent Framework
# Fill in your values before running. See README.md for details.
AZURE_AI_PROJECT_ENDPOINT=
AZURE_AI_MODEL_DEPLOYMENT_NAME=

# Cosmos DB — persistent memory
COSMOS_ENDPOINT=
COSMOS_KEY=
COSMOS_DATABASE=
COSMOS_CONTAINER=
COSMOS_TTL_DAYS=30
THAIN_CUSTOMER_ID=thain-demo-v2

# Azure AI Search — semantic recall
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_INDEX_NAME=
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_MODE=semantic
AZURE_SEARCH_TOP_K=3

# Azure AI Search — knowledge base
AZURE_SEARCH_DOCS_INDEX_NAME=
AZURE_SEARCH_DOCS_TOP_K=3

# Embeddings
AZURE_OPENAI_EMBEDDING_ENDPOINT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_API_KEY=
AZURE_OPENAI_EMBEDDING_API_VERSION=2024-02-15-preview

# Agentic action flags
ENABLE_TICKETS=true
ENABLE_NOTIFICATIONS=true
ENABLE_DOCS=true
ENABLE_WRITE_APPROVALS=true
TRIAGE_MODE=deterministic
ENABLE_RECALL=true
ENABLE_KNOWLEDGE=true

# LLM-as-judge evaluation
AZURE_OPENAI_EVAL_ENDPOINT=
AZURE_OPENAI_EVAL_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EVAL_API_KEY=
AZURE_OPENAI_EVAL_API_VERSION=2024-02-15-preview

# Sprint 2.1 — cost telemetry pricing rates (run s2.1-01-sync-openai-pricing.ps1 to populate)
THAIN_COST_INPUT_PER_1K_USD=
THAIN_COST_OUTPUT_PER_1K_USD=

# Sprint 2.2 — performance optimisation controls (run s2.2-01-configure-optimization.ps1 to populate)
THAIN_MODEL_PROFILE=standard
THAIN_ENABLE_RESPONSE_COMPACTION=true
THAIN_RESPONSE_SUMMARY_MAX_CHARS=300
THAIN_RESPONSE_SUGGEST_MAX_CHARS=520
THAIN_ENABLE_CACHE=true
THAIN_CACHE_TTL_SECONDS=120
THAIN_CACHE_MAX_ENTRIES=200

# Sprint 2.3 — reliability controls (run s2.3-01-configure-reliability.ps1 to populate)
THAIN_ENABLE_RELIABILITY=true
THAIN_RETRY_MAX_ATTEMPTS=3
THAIN_RETRY_BASE_DELAY_MS=250
THAIN_RETRY_MAX_DELAY_MS=2000
THAIN_RETRY_JITTER_RATIO=0.2
THAIN_DEPENDENCY_COOLDOWN_SECONDS=30
THAIN_DEPENDENCY_FAILURE_THRESHOLD=2
THAIN_TIMEOUT_OPENAI_MS=45000
THAIN_TIMEOUT_SEARCH_MS=8000
THAIN_TIMEOUT_COSMOS_MS=5000

# Chaos flags — set to true and redeploy to simulate dependency failures (default: false)
THAIN_CHAOS_SIMULATE_OPENAI_FAILURE=false
THAIN_CHAOS_SIMULATE_SEARCH_FAILURE=false
THAIN_CHAOS_SIMULATE_COSMOS_FAILURE=false

# SLO thresholds (used by s2.3-02-provision-reliability-alerts.ps1)
THAIN_SLO_ERROR_RATE_PCT=5
THAIN_SLO_ERROR_WINDOW_MIN=15
THAIN_SLO_P95_LATENCY_MS=30000
THAIN_SLO_P95_WINDOW_MIN=15
THAIN_SLO_DEP_FAILURE_COUNT=3
THAIN_SLO_DEP_FAILURE_WINDOW_MIN=5
