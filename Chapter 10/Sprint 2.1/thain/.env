# Azure OpenAI / Agent Framework
# Fill in your values before running. See README.md for details.
AZURE_AI_PROJECT_ENDPOINT=
AZURE_AI_MODEL_DEPLOYMENT_NAME=

# Cosmos DB — persistent memory
COSMOS_ENDPOINT=
COSMOS_KEY=
COSMOS_DATABASE=
COSMOS_CONTAINER=
COSMOS_TTL_DAYS=30
THAIN_CUSTOMER_ID=thain-demo-v2

# Azure AI Search — semantic recall
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_INDEX_NAME=
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_MODE=semantic
AZURE_SEARCH_TOP_K=3

# Azure AI Search — knowledge base
AZURE_SEARCH_DOCS_INDEX_NAME=
AZURE_SEARCH_DOCS_TOP_K=3

# Embeddings
AZURE_OPENAI_EMBEDDING_ENDPOINT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_API_KEY=
AZURE_OPENAI_EMBEDDING_API_VERSION=2024-02-15-preview

# Agentic action flags
ENABLE_TICKETS=true
ENABLE_NOTIFICATIONS=true
ENABLE_DOCS=true
ENABLE_WRITE_APPROVALS=true
TRIAGE_MODE=deterministic
ENABLE_RECALL=true
ENABLE_KNOWLEDGE=true

# LLM-as-judge evaluation
AZURE_OPENAI_EVAL_ENDPOINT=
AZURE_OPENAI_EVAL_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EVAL_API_KEY=
AZURE_OPENAI_EVAL_API_VERSION=2024-02-15-preview

# Sprint 2.1 — cost telemetry pricing rates (run s2.1-01-sync-openai-pricing.ps1 to populate)
THAIN_COST_INPUT_PER_1K_USD=
THAIN_COST_OUTPUT_PER_1K_USD=
